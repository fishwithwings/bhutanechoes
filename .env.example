# ---- Supabase (client-safe, exposed to browser) ----
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- Supabase (server-only, NEVER expose to browser) ----
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Stripe (server-only) ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Platform commission percentage (e.g. 15 = 15%)
PLATFORM_COMMISSION_PCT=15

# ---- Resend (transactional email, server-only) ----
RESEND_API_KEY=re_xxx
FROM_EMAIL=bookings@bhutanechoes.com

# Public base URL of the deployed site (used for Stripe redirect URLs)
PUBLIC_SITE_URL=http://localhost:4321
