---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
---
<Layout title="Page not found — Bhutan Echoes">
  <section class="container-x flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
    <p class="font-serif text-7xl font-bold text-gold">404</p>
    <h1 class="mt-4 font-serif text-3xl font-bold">This trail doesn't exist</h1>
    <p class="mt-3 max-w-md text-forest/65">
      The page you're looking for has wandered off into the mountains. Let's get you
      back on the path.
    </p>
    <div class="mt-8 flex gap-3">
      <a href="/" class="btn-primary">Go home</a>
      <a href="/tours" class="btn-outline">Browse tours</a>
    </div>
  </section>
</Layout>
