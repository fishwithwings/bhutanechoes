---
import Layout from '../layouts/Layout.astro';
export const prerender = false;
---
<Layout title="My account — Bhutan Echoes">
  <section class="container-x py-10">
    <div id="loading" class="py-20 text-center text-forest/50">Loading your account…</div>

    <div id="acct" class="hidden space-y-8 max-w-3xl mx-auto">
      <!-- Header -->
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <h1 class="font-serif text-3xl font-bold">My account</h1>
          <p id="welcome" class="text-forest/60"></p>
        </div>
        <button id="signout" class="btn-outline">Sign out</button>
      </div>

      <!-- Bookings -->
      <div class="card p-6">
        <h2 class="font-serif text-xl font-semibold mb-1">My bookings</h2>
        <p class="text-sm text-forest/55 mb-5">Upcoming and past tours.</p>
        <div id="bookings-list">
          <p class="text-sm text-forest/50">No bookings yet. <a href="/tours" class="text-gold-dark hover:underline">Browse tours →</a></p>
        </div>
      </div>

      <!-- Reviews -->
      <div class="card p-6">
        <h2 class="font-serif text-xl font-semibold mb-1">My reviews</h2>
        <p class="text-sm text-forest/55 mb-5">Reviews you've left for guides.</p>
        <div id="reviews-list">
          <p class="text-sm text-forest/50">No reviews yet.</p>
        </div>
      </div>

      <!-- Profile settings -->
      <div class="card p-6">
        <h2 class="font-serif text-xl font-semibold mb-5">Profile settings</h2>
        <form id="profile-form" class="space-y-4">
          <div>
            <label class="label" for="p-name">Full name</label>
            <input class="input" id="p-name" type="text" autocomplete="name" />
          </div>
          <div>
            <label class="label" for="p-email">Email</label>
            <input class="input" id="p-email" type="email" autocomplete="email" disabled />
            <p class="mt-1 text-xs text-forest/45">Email cannot be changed here.</p>
          </div>
          <p id="profile-err" class="hidden rounded-lg bg-red-50 px-3 py-2 text-sm text-red-700"></p>
          <p id="profile-ok" class="hidden rounded-lg bg-green-50 px-3 py-2 text-sm text-green-700">Saved!</p>
          <button type="submit" class="btn-primary">Save changes</button>
        </form>
      </div>
    </div>

    <!-- Not signed in -->
    <div id="gate" class="hidden py-20 text-center">
      <p class="text-forest/60 mb-4">You need to be signed in to view your account.</p>
      <a href="/login" class="btn-primary">Sign in</a>
    </div>
  </section>
</Layout>

<script>
  import { browserClient } from '../lib/supabase-browser';
  const sb = browserClient();

  const { data: { user } } = await sb.auth.getUser();
  const loading = document.getElementById('loading')!;
  const acct = document.getElementById('acct')!;
  const gate = document.getElementById('gate')!;

  if (!user) {
    loading.classList.add('hidden');
    gate.classList.remove('hidden');
  } else {
    loading.classList.add('hidden');
    acct.classList.remove('hidden');

    // Welcome
    const name = user.user_metadata?.full_name ?? user.email ?? 'there';
    document.getElementById('welcome')!.textContent = `Welcome back, ${name}`;

    // Prefill profile
    (document.getElementById('p-name') as HTMLInputElement).value = user.user_metadata?.full_name ?? '';
    (document.getElementById('p-email') as HTMLInputElement).value = user.email ?? '';

    // Load bookings
    const { data: bookings } = await sb
      .from('bookings')
      .select('id, tour_id, guide_id, start_date, status, total_cents, tours(name), guides(name)')
      .eq('guest_user_id', user.id)
      .order('start_date', { ascending: false });

    const bookingsList = document.getElementById('bookings-list')!;
    if (bookings && bookings.length > 0) {
      bookingsList.innerHTML = bookings.map((b: any) => {
        const date = b.start_date ? new Date(b.start_date).toLocaleDateString('en-US', { dateStyle: 'medium' }) : '—';
        const price = b.total_cents ? `$${(b.total_cents / 100).toFixed(0)}` : '—';
        const statusColor: Record<string, string> = {
          confirmed: 'bg-green-100 text-green-700',
          pending: 'bg-yellow-100 text-yellow-700',
          cancelled: 'bg-red-100 text-red-700',
          completed: 'bg-forest/10 text-forest',
        };
        const cls = statusColor[b.status] ?? 'bg-forest/10 text-forest';
        return `<div class="flex items-center justify-between gap-4 py-3 border-b border-forest/8 last:border-0">
          <div>
            <p class="font-medium text-sm">${b.tours?.name ?? 'Tour'}</p>
            <p class="text-xs text-forest/55">with ${b.guides?.name ?? 'Guide'} · ${date}</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm font-medium">${price}</span>
            <span class="rounded-full px-2 py-0.5 text-xs font-medium ${cls}">${b.status}</span>
          </div>
        </div>`;
      }).join('');
    }

    // Load reviews
    const { data: reviews } = await sb
      .from('reviews')
      .select('id, rating, comment, created_at, guides(name)')
      .eq('guest_user_id', user.id)
      .order('created_at', { ascending: false });

    const reviewsList = document.getElementById('reviews-list')!;
    if (reviews && reviews.length > 0) {
      reviewsList.innerHTML = reviews.map((r: any) => {
        const stars = '★'.repeat(r.rating) + '☆'.repeat(5 - r.rating);
        const date = new Date(r.created_at).toLocaleDateString('en-US', { dateStyle: 'medium' });
        return `<div class="py-3 border-b border-forest/8 last:border-0">
          <div class="flex items-center justify-between gap-2 mb-1">
            <p class="font-medium text-sm">${r.guides?.name ?? 'Guide'}</p>
            <p class="text-xs text-forest/45">${date}</p>
          </div>
          <p class="text-gold text-sm">${stars}</p>
          ${r.comment ? `<p class="mt-1 text-sm text-forest/70">${r.comment}</p>` : ''}
        </div>`;
      }).join('');
    }

    // Sign out
    document.getElementById('signout')?.addEventListener('click', async () => {
      await sb.auth.signOut();
      window.location.href = '/';
    });

    // Save profile
    const profileForm = document.getElementById('profile-form') as HTMLFormElement;
    const profileErr = document.getElementById('profile-err')!;
    const profileOk = document.getElementById('profile-ok')!;
    profileForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      profileErr.classList.add('hidden');
      profileOk.classList.add('hidden');
      const name = (document.getElementById('p-name') as HTMLInputElement).value.trim();
      const { error } = await sb.auth.updateUser({ data: { full_name: name } });
      if (error) {
        profileErr.textContent = error.message;
        profileErr.classList.remove('hidden');
      } else {
        profileOk.classList.remove('hidden');
      }
    });
  }
</script>
