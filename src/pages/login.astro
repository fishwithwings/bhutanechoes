---
import Layout from '../layouts/Layout.astro';
export const prerender = false;
---
<Layout title="Sign in — Bhutan Echoes">
  <section class="container-x flex min-h-[70vh] items-center justify-center py-16">
    <div class="card w-full max-w-md p-8">

      <!-- Tabs -->
      <div class="flex gap-1 rounded-xl bg-cream-dark p-1 mb-6">
        <button id="tab-signin" class="flex-1 rounded-lg py-2 text-sm font-medium transition-colors bg-white text-forest shadow-sm">Sign in</button>
        <button id="tab-signup" class="flex-1 rounded-lg py-2 text-sm font-medium transition-colors text-forest/55 hover:text-forest">Create account</button>
      </div>

      <!-- Sign in form -->
      <div id="panel-signin">
        <form id="login-form" class="space-y-4">
          <div>
            <label class="label" for="email">Email</label>
            <input class="input" type="email" id="email" name="email" required autocomplete="email" />
          </div>
          <div>
            <label class="label" for="password">Password</label>
            <input class="input" type="password" id="password" name="password" required autocomplete="current-password" />
          </div>
          <p id="login-err" class="hidden rounded-lg bg-red-50 px-3 py-2 text-sm text-red-700"></p>
          <button type="submit" id="login-btn" class="btn-primary w-full">Sign in</button>
        </form>
        <p class="mt-5 text-center text-sm text-forest/60">
          Want to guide? <a href="/register" class="font-medium text-gold-dark hover:underline">Apply here</a>
        </p>
      </div>

      <!-- Sign up form -->
      <div id="panel-signup" class="hidden">
        <form id="signup-form" class="space-y-4">
          <div>
            <label class="label" for="su-name">Full name</label>
            <input class="input" type="text" id="su-name" name="name" required autocomplete="name" />
          </div>
          <div>
            <label class="label" for="su-email">Email</label>
            <input class="input" type="email" id="su-email" name="email" required autocomplete="email" />
          </div>
          <div>
            <label class="label" for="su-password">Password</label>
            <input class="input" type="password" id="su-password" name="password" required minlength="8" autocomplete="new-password" />
            <p class="mt-1 text-xs text-forest/45">Min 8 characters</p>
          </div>
          <p id="signup-err" class="hidden rounded-lg bg-red-50 px-3 py-2 text-sm text-red-700"></p>
          <button type="submit" id="signup-btn" class="btn-primary w-full">Create account</button>
        </form>

        <div id="signup-success" class="hidden text-center py-4">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-green-100">
            <svg width="24" height="24" fill="none" stroke="#16a34a" stroke-width="2.5"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h2 class="mt-3 font-serif text-xl font-bold">Check your email</h2>
          <p class="mt-2 text-sm text-forest/65">We sent a confirmation link to your email address. Click it to activate your account, then come back to sign in.</p>
          <button id="back-to-signin" class="btn-outline mt-5 w-full">Back to sign in</button>
        </div>

        <p id="signup-footer" class="mt-5 text-center text-sm text-forest/60">
          Want to guide? <a href="/register" class="font-medium text-gold-dark hover:underline">Apply as a guide instead</a>
        </p>
      </div>

    </div>
  </section>
</Layout>

<script>
  import { browserClient } from '../lib/supabase-browser';

  const sb = browserClient();

  // Tab switching
  const tabSignin = document.getElementById('tab-signin')!;
  const tabSignup = document.getElementById('tab-signup')!;
  const panelSignin = document.getElementById('panel-signin')!;
  const panelSignup = document.getElementById('panel-signup')!;

  tabSignin.addEventListener('click', () => {
    tabSignin.className = 'flex-1 rounded-lg py-2 text-sm font-medium transition-colors bg-white text-forest shadow-sm';
    tabSignup.className = 'flex-1 rounded-lg py-2 text-sm font-medium transition-colors text-forest/55 hover:text-forest';
    panelSignin.classList.remove('hidden');
    panelSignup.classList.add('hidden');
  });
  tabSignup.addEventListener('click', () => {
    tabSignup.className = 'flex-1 rounded-lg py-2 text-sm font-medium transition-colors bg-white text-forest shadow-sm';
    tabSignin.className = 'flex-1 rounded-lg py-2 text-sm font-medium transition-colors text-forest/55 hover:text-forest';
    panelSignup.classList.remove('hidden');
    panelSignin.classList.add('hidden');
  });

  // Route after sign in
  async function routeByRole() {
    const { data: { user } } = await sb.auth.getUser();
    if (!user) return;
    const { data: profile } = await sb.from('profiles').select('role').eq('id', user.id).maybeSingle();
    if (profile?.role === 'admin') window.location.href = '/admin';
    else if (profile?.role === 'guide') window.location.href = '/dashboard';
    else window.location.href = '/account';
  }
  routeByRole().catch(() => {});

  // Sign in
  const loginForm = document.getElementById('login-form') as HTMLFormElement;
  const loginErr = document.getElementById('login-err')!;
  const loginBtn = document.getElementById('login-btn') as HTMLButtonElement;

  loginForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    loginErr.classList.add('hidden');
    loginBtn.disabled = true; loginBtn.textContent = 'Signing in…';
    const fd = new FormData(loginForm);
    try {
      const { error } = await sb.auth.signInWithPassword({
        email: String(fd.get('email')),
        password: String(fd.get('password')),
      });
      if (error) throw error;
      await routeByRole();
    } catch (e: any) {
      loginErr.textContent = e.message ?? 'Sign in failed.';
      loginErr.classList.remove('hidden');
      loginBtn.disabled = false; loginBtn.textContent = 'Sign in';
    }
  });

  // Sign up
  const signupForm = document.getElementById('signup-form') as HTMLFormElement;
  const signupErr = document.getElementById('signup-err')!;
  const signupSuccess = document.getElementById('signup-success')!;
  const signupBtn = document.getElementById('signup-btn') as HTMLButtonElement;

  signupForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    signupErr.classList.add('hidden');
    signupSuccess.classList.add('hidden');
    signupBtn.disabled = true; signupBtn.textContent = 'Creating account…';
    const fd = new FormData(signupForm);
    try {
      const { error } = await sb.auth.signUp({
        email: String(fd.get('email')),
        password: String(fd.get('password')),
        options: { data: { full_name: String(fd.get('name')) } },
      });
      if (error) throw error;
      signupForm.classList.add('hidden');
      document.getElementById('signup-footer')!.classList.add('hidden');
      signupSuccess.classList.remove('hidden');
    } catch (e: any) {
      signupErr.textContent = e.message ?? 'Sign up failed.';
      signupErr.classList.remove('hidden');
      signupBtn.disabled = false; signupBtn.textContent = 'Create account';
    }
  });

  document.getElementById('back-to-signin')?.addEventListener('click', () => {
    tabSignin.click();
  });
</script>
