---
import Layout from '../../layouts/Layout.astro';
import TourCard from '../../components/TourCard.astro';
import { getTours, getGuideCounts } from '../../lib/data';

export const prerender = false;

const env = (Astro.locals as any).runtime?.env;
const tours = await getTours(env);
const counts = await getGuideCounts(env);

// Unique regions and difficulties for filter dropdowns
const regions = [...new Set(tours.map((t) => t.region).filter(Boolean))].sort();
const difficulties = ['easy', 'moderate', 'challenging', 'strenuous'];

const POPULAR_SLUGS = [
  'tigers-nest-hike',
  'punakha-day-tour',
  'druk-path-trek',
  'western-bhutan-grand-tour',
  'thimphu-cultural-tour',
];
const popularTours = POPULAR_SLUGS.map(s => tours.find(t => t.slug === s)).filter(Boolean) as typeof tours;

const listingJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ItemList",
      "name": "Bhutan Tours & Treks",
      "description": "Licensed local guides for every Bhutan tour and trek — cultural journeys, festival tours, luxury lodges and Himalayan expeditions.",
      "url": "https://bhutanechoes.com/tours",
      "numberOfItems": tours.length,
      "itemListElement": tours.map((t, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": `https://bhutanechoes.com/tours/${t.slug}`,
        "name": t.name,
      })),
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://bhutanechoes.com" },
        { "@type": "ListItem", "position": 2, "name": "Tours & Treks", "item": "https://bhutanechoes.com/tours" },
      ],
    },
  ],
};
---
<Layout title="Bhutan Tours & Treks — Book a Licensed Local Guide | Bhutan Echoes"
        description="Browse 10+ Bhutan tours and treks — cultural journeys, festival tours, luxury lodges and Himalayan expeditions. Book directly with a licensed local guide."
        jsonLd={listingJsonLd}>
  <section class="bg-cream-dark border-b border-forest/10">
    <div class="container-x py-14">
      <p class="eyebrow">Our catalogue</p>
      <h1 class="mt-2 font-serif text-4xl font-bold sm:text-5xl">Tours &amp; treks</h1>
      <p class="mt-3 max-w-2xl text-forest/70">
        Pick a journey, then choose from licensed local guides — all-inclusive packages from Essential to Luxury.
      </p>
    </div>
  </section>

  <!-- Filters -->
  <section class="sticky top-0 z-20 bg-white/90 backdrop-blur border-b border-forest/10">
    <div class="container-x py-3 flex flex-wrap items-center gap-3">
      <input id="search-input" type="search" placeholder="Search tours…"
             class="input !w-48 !py-2 text-sm" />

      <select id="filter-region" class="input !w-auto !py-2 text-sm">
        <option value="">All regions</option>
        {regions.map((r) => <option value={r}>{r}</option>)}
      </select>

      <select id="filter-difficulty" class="input !w-auto !py-2 text-sm">
        <option value="">Any difficulty</option>
        <option value="easy">Easy</option>
        <option value="moderate">Moderate</option>
        <option value="challenging">Challenging</option>
        <option value="strenuous">Strenuous</option>
      </select>

      <select id="filter-duration" class="input !w-auto !py-2 text-sm">
        <option value="">Any length</option>
        <option value="1">Day trip (1 day)</option>
        <option value="2-4">Short (2–4 days)</option>
        <option value="5-8">Medium (5–8 days)</option>
        <option value="9+">Long (9+ days)</option>
      </select>

      <select id="filter-type" class="input !w-auto !py-2 text-sm">
        <option value="">All types</option>
        <option value="cultural">Cultural</option>
        <option value="festival">Festival</option>
        <option value="luxury">Luxury</option>
        <option value="trekking">Trekking</option>
        <option value="adventure">Adventure</option>
      </select>

      <select id="filter-tier" class="input !w-auto !py-2 text-sm">
        <option value="">All budgets</option>
        <option value="basic">Essential</option>
        <option value="classic">Classic</option>
        <option value="luxury">Luxury</option>
      </select>

      <span id="filter-count" class="ml-auto text-xs text-forest/50"></span>
      <button id="filter-clear" class="hidden btn-ghost !py-1.5 !px-3 text-xs">Clear filters</button>
    </div>
  </section>

  <!-- Traveler favorites -->
  <section class="container-x py-14 border-b border-forest/10">
    <div class="flex items-center gap-3 mb-1">
      <h2 class="font-serif text-2xl font-semibold text-forest">Traveler favorites</h2>
      <span class="pill-gold text-xs">Most popular</span>
    </div>
    <p class="text-forest/60 text-sm mb-7">The experiences travelers book most — consistently rated best across the web.</p>
    <div class="grid gap-7 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
      {popularTours.map((tour) => (
        <div
          class="tour-card"
          data-slug={tour.slug}
          data-name={tour.name.toLowerCase()}
          data-region={tour.region ?? ''}
          data-difficulty={tour.difficulty ?? ''}
          data-duration={tour.duration_days}
          data-min-price={tour.min_price_cents}
          data-summary={tour.summary?.toLowerCase() ?? ''}
          data-type={tour.tour_type ?? ''}
        >
          <TourCard tour={tour} guideCount={counts[tour.id]} />
        </div>
      ))}
    </div>
  </section>

  <section class="container-x py-14">
    <!-- Tours section -->
    <div id="tours">
      <h2 class="font-serif text-2xl font-semibold text-forest mb-1">Tours</h2>
      <p class="text-forest/60 text-sm mb-7">Cultural journeys, day trips and multi-day touring packages.</p>
      <div id="tours-grid" class="grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
        {tours.filter(t => !['tigers-nest-hike','druk-path-trek','jumolhari-trek'].includes(t.slug)).map((tour) => (
          <div
            class="tour-card"
            data-slug={tour.slug}
            data-name={tour.name.toLowerCase()}
            data-region={tour.region ?? ''}
            data-difficulty={tour.difficulty ?? ''}
            data-duration={tour.duration_days}
            data-min-price={tour.min_price_cents}
            data-summary={tour.summary?.toLowerCase() ?? ''}
            data-type={tour.tour_type ?? ''}
          >
            <TourCard tour={tour} guideCount={counts[tour.id]} />
          </div>
        ))}
      </div>
      <p id="no-results-tours" class="hidden mt-8 text-sm text-forest/50">No tours match your filters.</p>
    </div>

    <!-- Hikes section -->
    <div id="hikes" class="mt-16 scroll-mt-24">
      <h2 class="font-serif text-2xl font-semibold text-forest mb-1">Hikes &amp; treks</h2>
      <p class="text-forest/60 text-sm mb-7">On-foot adventures from a half-day climb to a 13-day Himalayan expedition.</p>
      <div id="treks-grid" class="grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
        {tours.filter(t => ['tigers-nest-hike','druk-path-trek','jumolhari-trek'].includes(t.slug)).map((tour) => (
          <div
            class="tour-card"
            data-slug={tour.slug}
            data-name={tour.name.toLowerCase()}
            data-region={tour.region ?? ''}
            data-difficulty={tour.difficulty ?? ''}
            data-duration={tour.duration_days}
            data-min-price={tour.min_price_cents}
            data-summary={tour.summary?.toLowerCase() ?? ''}
          >
            <TourCard tour={tour} guideCount={counts[tour.id]} />
          </div>
        ))}
      </div>
      <p id="no-results-treks" class="hidden mt-8 text-sm text-forest/50">No hikes match your filters.</p>
    </div>

    <p id="no-results" class="hidden mt-16 text-center text-forest/55">No results match your filters. <button id="clear-all" class="underline">Clear all</button></p>
  </section>
</Layout>

<script>
  const search   = document.getElementById('search-input') as HTMLInputElement;
  const region   = document.getElementById('filter-region') as HTMLSelectElement;
  const diff     = document.getElementById('filter-difficulty') as HTMLSelectElement;
  const duration = document.getElementById('filter-duration') as HTMLSelectElement;
  const typeEl   = document.getElementById('filter-type') as HTMLSelectElement;
  const tier     = document.getElementById('filter-tier') as HTMLSelectElement;
  const count    = document.getElementById('filter-count')!;
  const clearBtn = document.getElementById('filter-clear')!;
  const noRes    = document.getElementById('no-results')!;
  const noResTours = document.getElementById('no-results-tours')!;
  const noResTreks = document.getElementById('no-results-treks')!;
  const clearAll = document.getElementById('clear-all')!;
  const cards    = Array.from(document.querySelectorAll('.tour-card')) as HTMLElement[];

  const TIER_MAX: Record<string, number> = { basic: 80_000, classic: 150_000, luxury: Infinity };
  const TIER_MIN: Record<string, number> = { basic: 0, classic: 80_001, luxury: 150_001 };

  function filter() {
    const q = search.value.toLowerCase().trim();
    const r = region.value;
    const d = diff.value;
    const dur = duration.value;
    const tp = typeEl.value;
    const t = tier.value;

    const hasFilter = q || r || d || dur || tp || t;
    clearBtn.classList.toggle('hidden', !hasFilter);

    let visibleTours = 0;
    let visibleTreks = 0;

    cards.forEach((card) => {
      const name    = card.dataset.name ?? '';
      const summary = card.dataset.summary ?? '';
      const days    = parseInt(card.dataset.duration ?? '0', 10);
      const price   = parseInt(card.dataset.minPrice ?? '0', 10);
      const isTrek  = card.dataset.slug?.includes('trek');

      const matchQ  = !q  || name.includes(q) || summary.includes(q);
      const matchR  = !r  || card.dataset.region === r;
      const matchD  = !d  || card.dataset.difficulty === d;
      const matchTp = !tp || card.dataset.type === tp;
      const matchT  = !t  || (price >= TIER_MIN[t] && price <= TIER_MAX[t]);
      let matchDur = true;
      if (dur === '1') matchDur = days === 1;
      else if (dur === '2-4') matchDur = days >= 2 && days <= 4;
      else if (dur === '5-8') matchDur = days >= 5 && days <= 8;
      else if (dur === '9+') matchDur = days >= 9;

      const show = matchQ && matchR && matchD && matchTp && matchT && matchDur;
      card.classList.toggle('hidden', !show);
      if (show) isTrek ? visibleTreks++ : visibleTours++;
    });

    const total = visibleTours + visibleTreks;
    count.textContent = hasFilter ? `${total} of ${cards.length} results` : '';
    noResTours.classList.toggle('hidden', visibleTours > 0);
    noResTreks.classList.toggle('hidden', visibleTreks > 0);
    noRes.classList.toggle('hidden', total > 0);
  }

  [search, region, diff, duration, typeEl, tier].forEach((el) => el.addEventListener('input', filter));

  function clearFilters() {
    search.value = ''; region.value = ''; diff.value = ''; duration.value = ''; typeEl.value = ''; tier.value = '';
    filter();
  }
  clearBtn.addEventListener('click', clearFilters);
  clearAll.addEventListener('click', clearFilters);
</script>
