---
import Layout from '../layouts/Layout.astro';
export const prerender = true;

const steps = [
  { n: '1', t: 'Choose your tour', d: 'Browse six signature Bhutan tours and treks. Each shows a fair price range set by our team.' },
  { n: '2', t: 'Pick your guide', d: 'Compare licensed local guides by experience, languages, reviews and the price they have set.' },
  { n: '3', t: 'Message your guide', d: 'Chat directly with your guide before you book — ask questions, share preferences, and plan together.' },
  { n: '4', t: 'Book & pay securely', d: 'Choose your date and group size and pay online via Stripe. Your guide is confirmed instantly.' },
  { n: '5', t: 'Travel', d: 'Meet your guide in Bhutan and experience the kingdom through the eyes of someone who lives it.' },
];
const faqs = [
  { q: 'Who sets the prices?', a: 'Our team sets a fair minimum and maximum price band for each tour. Each guide chooses their own price within that band, so you always pay a fair rate.' },
  { q: 'Are the guides licensed?', a: 'Yes. Every guide is licensed by the Tourism Council of Bhutan and reviewed by our team before being approved on the platform.' },
  { q: 'How are payments handled?', a: 'You pay the full amount securely at booking via Stripe. The platform keeps a small commission and the rest is paid directly to your guide.' },
  { q: 'Is the price per person or per group?', a: 'Prices are shown per person. Your total is the per-person price multiplied by your group size.' },
  { q: 'Can I cancel?', a: "Cancellation terms depend on the tour and timing. Contact us and we'll coordinate with your guide." },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---
<Layout title="How it works — Bhutan Echoes" description="Learn how Bhutan Echoes works — browse tours, choose a licensed local guide, and book securely online." jsonLd={jsonLd}>
  <section class="bg-cream-dark border-b border-forest/10">
    <div class="container-x py-14">
      <p class="eyebrow">How it works</p>
      <h1 class="mt-2 font-serif text-4xl font-bold sm:text-5xl">Fair, direct, unforgettable</h1>
      <p class="mt-3 max-w-2xl text-forest/70">
        Bhutan Echoes connects travelers directly with licensed local guides — no
        bloated agency markups, just a fair price and a real connection.
      </p>
    </div>
  </section>

  <section class="container-x py-16">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      {steps.map((s) => (
        <div>
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gold font-serif text-lg font-bold text-white">{s.n}</div>
          <h3 class="mt-4 font-serif text-xl font-semibold">{s.t}</h3>
          <p class="mt-2 text-sm leading-relaxed text-forest/70">{s.d}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-cream-dark">
    <div class="container-x py-16">
      <h2 class="font-serif text-3xl font-bold">Frequently asked questions</h2>
      <div class="mt-8 max-w-3xl divide-y divide-forest/10">
        {faqs.map((f) => (
          <details class="group py-5">
            <summary class="flex cursor-pointer items-center justify-between font-medium text-forest">
              {f.q}
              <span class="text-gold transition-transform group-open:rotate-45 text-xl">+</span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-forest/70">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>
