---
import Layout from '../layouts/Layout.astro';
export const prerender = false;
---
<Layout title="Reset password — Bhutan Echoes">
  <section class="container-x flex min-h-[70vh] items-center justify-center py-16">
    <div class="card w-full max-w-md p-8">
      <h1 class="font-serif text-2xl font-bold mb-1">Set new password</h1>
      <p class="text-sm text-forest/60 mb-6">Enter your new password below.</p>

      <form id="reset-form" class="space-y-4">
        <div>
          <label class="label" for="new-password">New password</label>
          <input class="input" type="password" id="new-password" minlength="8" required autocomplete="new-password" />
          <p class="mt-1 text-xs text-forest/45">Min 8 characters</p>
        </div>
        <p id="reset-err" class="hidden rounded-lg bg-red-50 px-3 py-2 text-sm text-red-700"></p>
        <p id="reset-ok" class="hidden rounded-lg bg-green-50 px-3 py-2 text-sm text-green-700">Password updated! Redirecting…</p>
        <button type="submit" id="reset-btn" class="btn-primary w-full">Update password</button>
      </form>
    </div>
  </section>
</Layout>

<script>
  import { browserClient } from '../lib/supabase-browser';
  const sb = browserClient();

  const form    = document.getElementById('reset-form') as HTMLFormElement;
  const errEl   = document.getElementById('reset-err')!;
  const okEl    = document.getElementById('reset-ok')!;
  const btn     = document.getElementById('reset-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errEl.classList.add('hidden');
    btn.disabled = true; btn.textContent = 'Updating…';
    const password = (document.getElementById('new-password') as HTMLInputElement).value;
    const { error } = await sb.auth.updateUser({ password });
    if (error) {
      errEl.textContent = error.message;
      errEl.classList.remove('hidden');
      btn.disabled = false; btn.textContent = 'Update password';
    } else {
      okEl.classList.remove('hidden');
      setTimeout(() => window.location.href = '/login', 2000);
    }
  });
</script>
